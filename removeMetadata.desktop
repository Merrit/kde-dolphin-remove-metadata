 [Desktop Entry]
 Type=Service
 ServiceTypes=KonqPopupMenu/Plugin
 MimeType=image/*
 Actions=removeMetadata
 
 [Desktop Action removeMetadata]
 Name=Remove Metadata
 Name[de]=Metadaten löschen
 Name[fr]=Retirer les métadonnées
 Name[nl]=Metagegevens wissen
 Name[pl]=Usuń Metadane
 Name[zh_TW]=移除後設資料
 Icon=document-cleanup
 Exec=bash -c 'if ! command -v exiftool &>/dev/null; then kdialog --error "exiftool is not installed. Please install it first.\n\nFedora: sudo dnf install perl-Image-ExifTool\nUbuntu: sudo apt install libimage-exiftool-perl\nArch: sudo pacman -S perl-image-exiftool" --title "Missing Dependency"; exit 1; fi; kdialog --yesno "Exif metadata is going to be removed. Are you sure?" --title "Confirmation" && exiftool -all= "$@" -tagsfromfile @ -Orientation -overwrite_original' -- %U
